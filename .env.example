# NayePankh AI Assistant — Environment Variables
# Copy this file to .env and fill in your values

# ─── AI API (choose one) ──────────────────────────────────────────────────────
# Google Gemini (recommended)
GEMINI_API_KEY=AIzaSyB5TF-Me7yqvDvznOd5-ZJGwHPoioWleHE

# OpenAI (alternative — swap in backend/main.py)
